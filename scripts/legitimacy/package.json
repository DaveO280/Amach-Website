{
  "name": "@amach/legitimacy",
  "version": "0.1.0",
  "description": "Open-source legitimacy verification for Amach Health committed v2 leaves. Cryptographic anchoring + statistical / correlation / temporal / continuity checks against an on-chain Merkle root.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "amach-legitimacy-check": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepare": "npm run build",
    "cli": "ts-node src/cli.ts"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "poseidon-lite": "^0.2.0",
    "simple-statistics": "^7.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
