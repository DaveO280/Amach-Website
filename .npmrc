auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=true

# Security hardening
# Blocks postinstall/preinstall malware (most common npm supply chain vector).
# Native builds (sharp) are still allowed via pnpm.onlyBuiltDependencies in package.json.
ignore-scripts=true
enable-pre-post-scripts=false

# Pin registry to prevent .npmrc injection attacks that redirect to malicious registries
registry=https://registry.npmjs.org/