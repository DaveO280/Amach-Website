{
  "name": "amach-health",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "next dev --experimental-https --webpack",
    "dev:http": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "pnpm lint && pnpm type-check && pnpm test && next build --webpack",
    "vercel-build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "prepare": "husky install || true",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "clean": "rimraf .next && rimraf node_modules/.cache",
    "rebuild": "pnpm clean && pnpm install && pnpm build",
    "dev:clean": "pnpm clean:windows && pnpm dev",
    "build:clean": "rimraf .next && pnpm install && pnpm build",
    "build:prod": "rimraf .next && pnpm install --prod && pnpm build",
    "start:clean": "rimraf .next && pnpm build && pnpm start",
    "clean:windows": "rimraf --no-glob .next && rimraf --no-glob node_modules/.cache && pnpm rebuild",
    "pre-commit": "lint-staged && pnpm type-check && pnpm validate-docs",
    "validate-docs": "pnpm exec tsx scripts/validate-docs.ts",
    "clean-docs": "pnpm exec tsx scripts/validate-docs.ts --fix --no-confirm",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit:ci": "pnpm audit --audit-level=moderate --prod",
    "agent:isolate": "pnpm exec tsx scripts/test-single-agent.ts",
    "sleep:dedup": "pnpm exec tsx scripts/test-sleep-dedup.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1029.0",
    "@privy-io/react-auth": "3.21.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.0",
    "@tanstack/react-query": "^5.90.12",
    "@tensorflow/tfjs": "^4.22.0",
    "@types/papaparse": "^5.5.1",
    "@vercel/analytics": "^2.0.1",
    "@wagmi/core": "3.4.2",
    "axios": "1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "crypto-js": "4.2.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "formidable": "^3.5.4",
    "framer-motion": "^12.23.25",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "node-fetch": "^3.3.2",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "poseidon-lite": "^0.3.0",
    "pdfjs-dist": "4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^5.0.0",
    "recharts": "^3.8.1",
    "snarkjs": "^0.7.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "viem": "2.47.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@matterlabs/hardhat-zksync-deploy": "^1.8.0",
    "@matterlabs/hardhat-zksync-solc": "^1.5.1",
    "@matterlabs/hardhat-zksync-upgradable": "^1.10.0",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@openzeppelin/contracts": "^5.4.0",
    "@openzeppelin/contracts-upgradeable": "^5.4.0",
    "@openzeppelin/hardhat-upgrades": "3",
    "@playwright/test": "^1.58.2",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-path": "^3.1.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/d3-time": "^3.0.4",
    "@types/d3-timer": "^3.0.2",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.2",
    "@types/node-fetch": "^2.6.13",
    "@types/offscreencanvas": "^2019.7.3",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/seedrandom": "^3.0.8",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "ethers": "^5.8.0",
    "hardhat": "^2.27.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "rimraf": "^5.0.10",
    "sharp": "^0.34.5",
    "tailwindcss": "3.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zksync-web3": "^0.17.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "ignoredOptionalDependencies": [
      "canvas"
    ],
    "overrides": {
      "form-data": "^4.0.4",
      "axios": "1.15.0",
      "glob": "^10.5.0",
      "tough-cookie": "^4.1.3",
      "js-yaml": "^4.1.1",
      "yargs-parser": "^21.0.0",
      "cookie": "^0.7.2",
      "brace-expansion": "^2.0.3",
      "tmp": "^0.2.3",
      "next": "16.2.3",
      "h3": "1.15.9",
      "hono": "4.12.12",
      "defu": "6.1.5",
      "underscore": "1.13.8",
      "qs": "^6.14.2",
      "preact": "^10.28.2",
      "lodash": "^4.18.1",
      "diff@4.0.2": "4.0.4",
      "diff@5.2.0": "5.2.2",
      "undici": "^6.24.1",
      "tar": "^7.5.13",
      "fast-xml-parser": "5.5.7",
      "socket.io-parser": "4.2.6",
      "router>path-to-regexp": "8.4.0",
      "yaml": "1.10.3",
      "bn.js": "^5.2.3",
      "handlebars": "^4.7.9",
      "flatted": "^3.4.2",
      "ajv@^6.0.0": "^6.14.0",
      "serialize-javascript": "^7.0.5",
      "svgo": "^3.3.3",
      "immutable": "^4.3.8",
      "@tootallnate/once": "^3.0.1",
      "minimatch@^3.0.0": "^3.1.5",
      "minimatch@^5.0.0": "^5.1.9",
      "minimatch@^9.0.0": "^9.0.9"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "canvas",
        "request"
      ]
    },
    "_comment": {
      "audit-scope": "audit:ci uses --prod so only production dependencies are checked. Dev tooling (ts-jest/handlebars, hardhat/minimatch, eslint, webpack) has known CVEs but never runs in production — acceptable risk.",
      "tar": "CVE-2026-23745 + drive-relative linkpath issues; override pins 7.5.13+.",
      "brace-expansion": "GHSA-f886-m6hf-6m8v fixed in 2.0.3+ (2.0.1 was incorrectly pinned before).",
      "request": "The 'request' package has SSRF vulnerability (CVE-2023-28155) but is only used in dev/test via @nomiclabs/hardhat-waffle. It's deprecated and has no patched version. This is acceptable risk as it never runs in production.",
      "lodash": "CVE lodash _.template code injection (High): lodash 4.x is abandoned at 4.17.21, no patched version exists. Privy SDK pulls this in as a transitive dep. Attack requires caller to pass untrusted input to _.template() directly — Amach does not do this. Acceptable known risk until Privy removes the lodash dependency.",
      "elliptic": "Elliptic has a low-severity vulnerability (risky cryptographic implementation) but is a transitive dependency required by crypto libraries. This is tolerated as it's a low-risk issue and no alternative is available without breaking changes."
    },
    "patchedDependencies": {
      "viem": "patches/viem.patch"
    }
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "pnpm prettier --write",
      "pnpm eslint --fix"
    ],
    "**/*.{js,jsx,json,css,scss,md}": [
      "pnpm prettier --write"
    ]
  },
  "json.schemas": [
    {
      "fileMatch": [
        "/package.json"
      ],
      "url": "./package-schema.json"
    }
  ],
  "files": [
    "src",
    "my-health-app"
  ]
}
